# API Keys for Live Selling Academy
# これらの値は.envファイルに設定してください（.envはGitにアップロードされません）

# Anthropic API Key (AI coaching and feedback)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini API Key (音声生成用)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Pexels API Key (製品画像用 - 完全無料！)
# Get FREE API key at: https://www.pexels.com/api/new/
# Works WITHOUT API key using curated images!
# 100% free, no cost, no limits on basic tier
VITE_PEXELS_API_KEY=your_pexels_api_key_here_optional

# Unsplash API Key (製品画像用 - オプション)
# Get your key at: https://unsplash.com/developers
# Without this key, app will use SVG placeholders
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Video Analysis API Key (動画分析用)
VITE_VIDEO_API_KEY=your_video_api_key_here
